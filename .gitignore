# ==========================================
# 🛑 SECURITY: CRITICAL SECRETS 
# ==========================================
# We explicitly ignore the active pushing script because it contains 
# the author's live Personal Access Token (PAT).
# Only 'github_push_template.sh' will be committed to the public repo.
github_pusher.sh
.env
*.pem
*.key

